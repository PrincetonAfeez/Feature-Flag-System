# Copy to `.env` for local development. manage.py loads it automatically when
# python-dotenv is installed (pip install -e ".[dev]"). Real deployments should
# set these directly in the environment instead of committing a .env file.

# Django secret key. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=change-me

# Set to 0 to turn debug mode off.
DJANGO_DEBUG=1
